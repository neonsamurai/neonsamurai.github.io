agenten/ballentine,-george-t.-alias-\"force\"-(nils).html","agenten/drops,-steve-alias-\"fire\"-(mathias).html","agenten/jagoda,-ekatherina-alias-\"farsight\"-(kathi).html","agenten/smith,-bimmel-alias-\"foundry\"-(jonas).html","agenten/whatson,-priscilla-alias-\"figma\"-(maja).html"],"author":"","coverImageURL":"","fullURL":"agentenakte.html","pathToRoot":".","attachments":[],"createdTime":1782329625525,"modifiedTime":1782330322636,"sourceSize":321,"sourcePath":"Agentenakte.md","exportPath":"agentenakte.html","showInTree":true,"treeOrder":6,"backlinks":[],"type":"markdown"},"agenten/ballentine,-george-t.-alias-\"force\"-(nils).html":{"title":"Ballentine, George T. alias \"Force\" (Nils)","icon":"","description":"<img alt=\"Agent_Force.png\" src=\"media/agent_force.png\" target=\"_self\">KLASSIFIKATION: GEHEIM//NFDSUBJEKT: BALLENTINE, George T. alias \"FORCE\"\nGEB: 13.4.1983\nHAUPT OPERATIONSRAUM: Austin, TX\nSTATUS: AKTIV, Texas Highway Patrol\nMUTTER: Unbekannt\nVATER: Unbekannt\n(ANDERE ANGEHÖRIGE): UnbekanntNOTIZEN:","aliases":[],"inlineTags":[],"frontmatterTags":[],"headers":[{"heading":"PERSONALAKTE","level":1,"id":"PERSONALAKTE_0"},{"heading":"Fähigkeitsprofil","level":1,"id":"Fähigkeitsprofil_0"},{"heading":"Psychologisches Profil","level":1,"id":"Psychologisches_Profil_0"},{"heading":"Soziale Verbindungen","level":1,"id":"Soziale_Verbindungen_0"}],"links":[],"author":"","coverImageURL":"media/agent_force.png","fullURL":"agenten/ballentine,-george-t.-alias-\"force\"-(nils).html","pathToRoot":"..","attachments":["media/agent_force.png"],"createdTime":1782230773084,"modifiedTime":1782254418143,"sourceSize":380,"sourcePath":"Agenten/Ballentine, George T. alias \"Force\" (Nils).md","exportPath":"agenten/ballentine,-george-t.-alias-\"force\"-(nils).html","showInTree":true,"treeOrder":1,"backlinks":["agentenakte.html"],"type":"markdown"},"agenten/drops,-steve-alias-\"fire\"-(mathias).html":{"title":"Drops, Steve alias \"Fire\" (Mathias)","icon":"","description":"<img alt=\"Agent_Fire.png\" src=\"media/agent_fire.png\" target=\"_self\">KLASSIFIKATION: GEHEIM//NFDSUBJEKT: DROPS, Steve alias \"FIRE\"\nGEB: 13.4.1983\nHAUPT OPERATIONSRAUM: New York City, NY\nSTATUS: AKTIV, FBI\nMUTTER: Marie Drops\nVATER: Unbekannt\nSCHWESTER: Miranda Drops NOTIZEN:Körperlich eingeschränkt durch Skoliose und Lebensmittelunverträglichkeiten (Laktose). Außerordentlich intelligent. Stark ausgeprägte Stressresistent. Doktor der Computerwissenschaften (Schwerpunkt Microcontroller), Master of Arts der Rechtswissenschaften, Master of Arts der Betriebswirtschaftslehre. Experte in Überwachungstechnik. Spricht Mandarin Level B2Ausgeprägtes Bedürfnis, Menschen in Not zu Helfen. Starker Familiensinn. ADHSSMIRGLE: Schnappschildkröte, zu der der Agent eine enge emotionale Bindung aufgebaut hat. Patentier im Tierheim Queens (NYC)\nDROPS, Miranda: Schwester\nDROPS, Marie: Mutter","aliases":[],"inlineTags":[],"frontmatterTags":[],"headers":[{"heading":"PERSONALAKTE","level":1,"id":"PERSONALAKTE_0"},{"heading":"Fähigkeitsprofil","level":1,"id":"Fähigkeitsprofil_0"},{"heading":"Psychologisches Profil","level":1,"id":"Psychologisches_Profil_0"},{"heading":"Soziale Verbindungen","level":1,"id":"Soziale_Verbindungen_0"}],"links":[],"author":"","coverImageURL":"media/agent_fire.png","fullURL":"agenten/drops,-steve-alias-\"fire\"-(mathias).html","pathToRoot":"..","attachments":["media/agent_fire.png"],"createdTime":1782229750116,"modifiedTime":1782254426754,"sourceSize":1021,"sourcePath":"Agenten/Drops, Steve alias \"Fire\" (Mathias).md","exportPath":"agenten/drops,-steve-alias-\"fire\"-(mathias).html","showInTree":true,"treeOrder":2,"backlinks":["agentenakte.html"],"type":"markdown"},"agenten/jagoda,-ekatherina-alias-\"farsight\"-(kathi).html":{"title":"Jagoda, Ekatherina alias \"Farsight\" (Kathi)","icon":"","description":"<img alt=\"Agent_Farsight.png\" src=\"media/agent_farsight.png\" target=\"_self\">KLASSIFIKATION: GEHEIM//NFDSUBJEKT: JAGODA, Ekatherina alias \"FARSIGHT\"\nGEB: 13.4.1983\nHAUPT OPERATIONSRAUM: New York City, NY\nSTATUS: AKTIV, FBI\nMUTTER: Unbekannt\nVATER: Unbekannt\nBRUDER: Jakob JagodaNOTIZEN:Medizinstudium, sehr stark ausgeprägte analytische Fähigkeiten. Doktor der Psychiatrie, Master of Science der Biologie, Facharzt der allg. Medizin.Stark ausgeprägter Lern- und Forschungsdrang, HelferkomplexJAGODA, Jakob: Bruder\nMILLER, George: Doktorvater","aliases":[],"inlineTags":[],"frontmatterTags":[],"headers":[{"heading":"PERSONALAKTE","level":1,"id":"PERSONALAKTE_0"},{"heading":"Fähigkeitsprofil","level":1,"id":"Fähigkeitsprofil_0"},{"heading":"Psychologisches Profil","level":1,"id":"Psychologisches_Profil_0"},{"heading":"Soziale Verbindungen","level":1,"id":"Soziale_Verbindungen_0"}],"links":[],"author":"","coverImageURL":"media/agent_farsight.png","fullURL":"agenten/jagoda,-ekatherina-alias-\"farsight\"-(kathi).html","pathToRoot":"..","attachments":["media/agent_farsight.png"],"createdTime":1782229791936,"modifiedTime":1782330363514,"sourceSize":650,"sourcePath":"Agenten/Jagoda, Ekatherina alias \"Farsight\" (Kathi).md","exportPath":"agenten/jagoda,-ekatherina-alias-\"farsight\"-(kathi).html","showInTree":true,"treeOrder":3,"backlinks":["agentenakte.html"],"type":"markdown"},"agenten/smith,-bimmel-alias-\"foundry\"-(jonas).html":{"title":"Smith, Bimmel alias \"Foundry\" (Jonas)","icon":"","description":"<img alt=\"Agent_Foundry.png\" src=\"media/agent_foundry.png\" target=\"_self\">KLASSIFIKATION: GEHEIM//NFDSUBJEKT: SMITH, Bimmel alias \"FOUNDRY\"\nGEB: 13.4.1983\nHAUPT OPERATIONSRAUM: New York City (NY)\nSTATUS: AKTIV, DOD\nMUTTER: Jill Smith\nVATER: Jack SmithNOTIZEN:Körperlich fit, stark ausgeprägte analytische Fähigkeiten. Ausbildung zum Kommandosoldat SFOD-D, Experte in Nahkampf, Schusswaffen, schwere Waffen, Überwachung, Sprengmitteleinsatz. Einzelkämpferausbildung, Guerillataktiken.Verminderte Fähigkeit zu Empathie. Neigt zu Helfersyndrom, auch wenn dies von BOMMEL: Belgischer Schäferhund. Veteran aus der letzten Entsendung nach Afghanistan.\nSMITH, Jill und Jack: Eltern","aliases":[],"inlineTags":[],"frontmatterTags":[],"headers":[{"heading":"PERSONALAKTE","level":1,"id":"PERSONALAKTE_0"},{"heading":"Fähigkeitsprofil","level":1,"id":"Fähigkeitsprofil_0"},{"heading":"Psychologisches Profil","level":1,"id":"Psychologisches_Profil_0"},{"heading":"Soziale Verbindungen","level":1,"id":"Soziale_Verbindungen_0"}],"links":[],"author":"","coverImageURL":"media/agent_foundry.png","fullURL":"agenten/smith,-bimmel-alias-\"foundry\"-(jonas).html","pathToRoot":"..","attachments":["media/agent_foundry.png"],"createdTime":1782229739988,"modifiedTime":1782254436616,"sourceSize":785,"sourcePath":"Agenten/Smith, Bimmel alias \"Foundry\" (Jonas).md","exportPath":"agenten/smith,-bimmel-alias-\"foundry\"-(jonas).html","showInTree":true,"treeOrder":4,"backlinks":["agentenakte.html"],"type":"markdown"},"agenten/whatson,-priscilla-alias-\"figma\"-(maja).html":{"title":"Whatson, Priscilla alias \"Figma\" (Maja)","icon":"","description":"<img alt=\"Agent_Figma.png\" src=\"media/agent_figma.png\" target=\"_self\">KLASSIFIKATION: GEHEIM//NFDSUBJEKT: WHATSON, Priscilla alias \"FIGMA\"\nGEB: 13.4.1983\nHAUPT OPERATIONSRAUM: New York City, NY\nSTATUS: AKTIV, NY General Hospital (NYC)\nMUTTER: Unbekannt\nVATER: Unbekannt\n(ANDERE ANGEHÖRIGE): Carl Whatson (Ex-Ehemann)NOTIZEN:Fotografisches Gedächtnis, außerordentlich willensstark. Doktor der Psychologie, Master of Science der Biologie, Facharzt der allg. Medizin. Ausgeprägte MenschenkenntnisStark ausgeprägte Eigenständigkeit und Bedürfnis nach Unabhängigkeit, zielstrebig und karrierebewusst.\nTraumata durch frühen Tod der Eltern und später Entführungsfall sind unzureichend aufgearbeitet. Leidet an Schlafstörungen. Ist Entzug von Handlungsfähigkeit gegenüber außerordentlich resistent.WHATSON, Carl: Ehemann (geschieden)\nKURT, Eva: befreundete Ärztin im NY General Hospital\nPETERSON, Pam: ehem. Patientin","aliases":[],"inlineTags":[],"frontmatterTags":[],"headers":[{"heading":"PERSONALAKTE","level":1,"id":"PERSONALAKTE_0"},{"heading":"Fähigkeitsprofil","level":1,"id":"Fähigkeitsprofil_0"},{"heading":"Psychologisches Profil","level":1,"id":"Psychologisches_Profil_0"},{"heading":"Soziale Verbindungen","level":1,"id":"Soziale_Verbindungen_0"}],"links":[],"author":"","coverImageURL":"media/agent_figma.png","fullURL":"agenten/whatson,-priscilla-alias-\"figma\"-(maja).html","pathToRoot":"..","attachments":["media/agent_figma.png"],"createdTime":1782229698011,"modifiedTime":1782254447932,"sourceSize":1071,"sourcePath":"Agenten/Whatson, Priscilla alias \"Figma\" (Maja).md","exportPath":"agenten/whatson,-priscilla-alias-\"figma\"-(maja).html","showInTree":true,"treeOrder":5,"backlinks":["agentenakte.html"],"type":"markdown"}},"fileInfo":{"agentenakte.html":{"createdTime":1782329625525,"modifiedTime":1782330322636,"sourceSize":321,"sourcePath":"Agentenakte.md","exportPath":"agentenakte.html","showInTree":true,"treeOrder":6,"backlinks":[],"type":"markdown","data":null},"site-lib/scripts/graph-wasm.wasm":{"createdTime":1782250955137,"modifiedTime":1782250954089.5317,"sourceSize":23655,"sourcePath":"","exportPath":"site-lib/scripts/graph-wasm.wasm","showInTree":false,"treeOrder":0,"backlinks":[],"type":"other","data":null},"site-lib/fonts/70cc7ff27245e82ad414.ttf":{"createdTime":1782330408465,"modifiedTime":1782330408465,"sourceSize":192740,"sourcePath":"","exportPath":"site-lib/fonts/70cc7ff27245e82ad414.ttf","showInTree":false,"treeOrder":0,"backlinks":[],"type":"font","data":null},"site-lib/fonts/454577c22304619db035.ttf":{"createdTime":1782330408465,"modifiedTime":1782330408465,"sourceSize":161376,"sourcePath":"","exportPath":"site-lib/fonts/454577c22304619db035.ttf","showInTree":false,"treeOrder":0,"backlinks":[],"type":"font","data":null},"site-lib/fonts/52ac8f3034507f1d9e53.ttf":{"createdTime":1782330408465,"modifiedTime":1782330408465,"sourceSize":191568,"sourcePath":"","exportPath":"site-lib/fonts/52ac8f30